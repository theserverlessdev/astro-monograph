---
import { load } from '../lib/data';
const experience = load('experience.yaml');
---
<section id="experience" class="py-20 md:py-28 px-6 bg-surface scroll-mt-16">
  <div class="max-w-[960px] mx-auto">
    <div class="reveal">
      <p class="text-[14px] font-mono text-cern-blue tracking-[0.12em] uppercase mb-3">{experience.label}</p>
      <h2 class="font-display text-[32px] md:text-[44px] font-bold text-ink mb-12 tracking-[-0.01em]">
        {experience.heading}
      </h2>
    </div>

    <div class="border-l-2 border-cern-blue/20">
      {experience.jobs.map((job: any, i: number) => (
        <div class={`reveal flex ${i < experience.jobs.length - 1 ? 'pb-14' : ''}`}>
          <div class="w-3 h-3 rounded-full bg-cern-blue ring-[4px] ring-surface -ml-[7px] mt-[10px] shrink-0"></div>
          <div class="pl-6 min-w-0 flex-1">
            <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1 mb-2">
              <div>
                <h3 class="font-display text-[22px] font-bold text-ink m-0">{job.company}</h3>
                <p class="text-[16px] text-cern-blue font-medium m-0">{job.role}</p>
              </div>
              <span class="text-[14px] text-ink-tertiary font-mono" set:html={job.dateRange} />
            </div>
            <p class="text-[14px] text-ink-tertiary mt-0 mb-3">{job.location}</p>
            <p class="text-[17px] text-ink-secondary leading-[1.7] mt-0 mb-4">{job.description}</p>
            <div class="flex flex-wrap gap-1.5">
              {job.tech.map((t: string) => (
                <span class="inline-block px-2.5 py-1 text-[13px] font-medium rounded bg-cern-blue-wash text-cern-blue font-mono">{t}</span>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
